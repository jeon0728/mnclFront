@use '../../variable' as *;

//.main-layout-container
.main-layout-container {
  width: 100%;
  height: 100%;
}

.main__router-tab {
  flex: 1;
  display: flex;
  box-sizing: border-box;
  overflow-x: hidden;
  padding-bottom: 24px;
}

.content {
  height: calc(100% - $header-height);
  @include colors('background-color', mainBg);

  &__main {
    gap: 0;
    box-sizing: border-box;
  }
}
