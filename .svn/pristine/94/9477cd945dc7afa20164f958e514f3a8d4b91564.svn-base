@use '../../variable' as *;
@use '../../mixins/tables' as table;

// si 현황 테이블
.si-status {
  >ul {
    display: flex;
    flex-wrap: wrap;
    gap: 32px;

    >li {
      flex: 1 1 470px;
      display: flex;
      flex-direction: column;

      .title {
        margin-bottom: 16px;
        text-align: center;
        font-size: $fs-m;
        font-weight: 700;
        @include black('color', 30);
      }
    }
  }
}

.si-status-table {
  @include table.status-table;
}

.contents-inner {
  li.si-date-field {
    // 너무 길게 늘어나지 않도록 고정폭(최대폭)으로 제한
    flex: 0 1 420px;
    max-width: 420px;
  }

  .date-range-inputs {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .date-range-inputs>* {
    flex: 1 0 130px;
    min-width: 0;
  }
}