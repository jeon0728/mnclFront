@use 'variables/size' as *;
@use 'functions/colors' as *;

table {
	width: 100%;
	border-collapse: collapse;
	font-size: 12px;

	th, td {
		line-height: 28px;
		padding: 4px 8px;
		border-bottom-width: 1px;
		border-bottom-style: solid;
	}

	th {
		font-weight: 600;
		text-align: left;
		@include black('border-bottom-color', 70);
		@include black('color', 40);
	}

	td {
		@include black('border-bottom-color', 80);
		@include black('color', 20);
	}

	.center {
		text-align: center;
	}

	.right {
		text-align: right;
	}
}
