import { GridAdapter } from '@/shared/utils'

/**
 * GridAdapter 생성히기 위한 composable
 *
 * @description
 * - GridAdapter를 생성해 준다
 * - 한건씩 생성 가능
 *
 * @return TData[] - 생성된 데이터 리스트
 *
 * @example
 * ```ts
 * const gridAdapter = useGrid()
 * ```
 */
export const useGrid = () => {
  return ref<GridAdapter>()
}