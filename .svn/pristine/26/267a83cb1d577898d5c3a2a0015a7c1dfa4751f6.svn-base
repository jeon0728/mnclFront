@use '../../variable' as *;
@use '../../mixins/badges' as *;

.badge {
	&-outline {
		@include badge;
		&.success {
			@include badge-outline(successed);
		}
		&.pending {
			@include badge-outline(pending);
		}
		&.decline {
			@include badge-outline(declined);
		}
	}
	&-fill {
		@include badge;
		margin-left: 4px;
		padding: 4px 6px;
		border-radius: $rM;
		font-weight: 400;
		font-size: 10px;
		border: 0;
		&.success {
			@include badge-fill(completeBadge, completeBadgeBg);
		}
		&.pending {
			@include badge-fill(pendingBadge, pendingBadgeBg);
		}
		&.decline {
			@include badge-fill(overBadge, overBadgeBg);
		}
	}
}