@use '../../variable' as *;

.logo-updater {
    display: flex;
    align-items: center;
    gap: 8px;

    &-preview {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2px;
        width: 100px;
        height: 50px;
        border-radius: $rS;
        border: 1px dashed;
        overflow: hidden;
        font-size: $fs-xs;
        background-position: center;
        background-repeat: no-repeat;
        background-size: contain;
        background-color: #fff;
        @include black('color', 40);
        img {
            max-width: 100%;
            max-height: 100%;
            width: auto;
            height: auto;
            object-fit: contain;
            object-position: center;
        }
    }
}