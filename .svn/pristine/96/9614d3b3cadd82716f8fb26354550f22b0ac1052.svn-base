@use "../../variable" as *;

.z-tab {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100%;

  &__header-wrapper {
    position: sticky;
    // 스케쥴과의 z-index충돌로 높임
    z-index: 10;
    top: 0;
    left: 0;
    flex-shrink: 0;
    margin-top: 16px;
    background-color: transparent;
    border-bottom-width: 1px;
    border-bottom-style: solid;
    @include black("border-bottom-color", 70);
    @include colors('background-color', mainBg);
  }

  &__header {
    padding-inline-start: 0;
    position: relative;
    display: inline-flex;
    flex-wrap: nowrap;
    height: 100%;
    margin: 0;
    padding: 0;
    list-style: none;
    gap: 4px;

    &__list {
      cursor: pointer;
      padding: 6px 16px;
      font-size: $fs-m;
      border-bottom: 1px solid transparent;
      @include black("color", 20);

      &:not(.tab-no-active) {
        font-weight: 500;
        transform: translateY(1px);
        @include colors("border-bottom-color", primary);
        @include colors("color", primary);
      }

      &:hover.tab-no-active {
        @include colors("color", primary);
      }
    }
  }

  &__body-wrapper {
    flex: 1;
    min-height: 0;
    transition: all $tr-short-out;
  }
  &__body {

    .body__element {
      > .layout.w100p.flex.flex-column{
        gap: 0;
      }
      &.full-height {
        min-height: 100%;
      }
    }
  }

  //각 모드별 탭 정의는 이곳에서
  &.default-tab {
    .z-tab__body-wrapper {
      .z-tab__body {
        gap: 12px;
      }

      .tab-no-active {
        display: none;
      }
    }
  }

  &.flex-tab {
    .z-tab__body-wrapper {
      .z-tab__body {
        gap: 12px;
      }

      .tab-no-active {
      }
    }
  }
}
