@use '../../variable' as *;

// .modal-overlay
.modal{
  position: fixed;
  outline: none;
  border-radius: 16px;
  box-shadow: $shadow-normal;
  @include black('border-color', 80);
  &:not(.grap) {
    transition: none;
  }
  &-overlay{
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: inherit;
    pointer-events: auto;
    transition: 0.3s cubic-bezier(0.25, 0.8, 0.5, 1), z-index 1ms;
    outline: none;
    background-color: rgba(46, 46, 46, 0.1);
    @include black('background-color', 20, 0.1, #2e2e2e1a);
    &.none {
      background-color: transparent;
    }
  }
  &-wrapper{
    width: 100%;
    height: 100%;
  }
}

.modal__header:active{
  cursor: grabbing;
}

.modal{
  &__header{
    height: $modal-header-height;
    display: flex;
    align-items: center;
    border-radius: 16px 16px 0 0;
    padding: 4px 12px;
    border-bottom: 1px solid;
    @include black('border-bottom-color', 80);
    @include black('background-color', white);
  }
  &__title{
    align-items: center;

    span {
      font-size: $fs-title;
      font-weight: 500;
    }

    .title__icon {
      display: flex;
      gap: 8px;
      margin-left: auto;
      svg {
        width: 20px;
        height: 20px;
        transition: transform $tr-short;
        will-change: transform;
        @include black('color', 40);
      }
      > div {
        cursor: pointer;
        width: 20px;
        height: 20px;
        border-radius: $rS;
        transition: background-color $tr-short;
        &:hover {
          @include black('background-color', 80);
        }
        &:active > svg {
          transform: scale(0.9);
        }
      }
    }
  }
  &__content {
    padding-bottom: 12px;
    height: calc(100% - $modal-header-height);
    border-radius: 0 0 16px 16px;
    @include black('background-color', white);
  }
}

//resizer
.modal .resizer {
    position: absolute;
    z-index: 1;
    //top
    &.e{
      width: 5px;
      height: 100%;
      right: -1px;
      cursor: e-resize;
    }
    //bottom
    &.s{
      width: 100%;
      height: 5px;
      bottom: -1px;
      cursor: s-resize;
    }
    //cross
    &.se {
      width: 13px;
      height: 13px;
      bottom: 5px;
      right: 3px;
      cursor: se-resize;
      transform: rotate(-45deg);
      z-index: 2;
      &::after,
      &::before {
        content: '';
        position: absolute;
        width: 100%;
        height: 1px;
        border-radius: 50%;
        @include black('background-color', 40);
      }
      &::after {
        top: 5px;
        left: 0;
      }
      &::before {
        width: 60%;
        bottom: 3px;
        right: 3px;
      }
    }
}
//resizer

// 모달 커졌을 때 스타일 조정
.modal[style^="width: 99%"]{
  border-radius: 0;
  transition: all 0.3s ease-in-out;
  .modal__header{
    // border-radius: 0;
  }
  .modal__content{
    border-radius: 0;
  }
}

// 모달용 서치폼 라벨 스타일 조정
.modal__content .search-form-label {
  @include label;
}


.loading-wrapper {
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;

