@use "../../variable" as *;

//사이드메뉴 헤드
.side-menu-header {
  margin-left: auto;
  display: flex;
  gap: 12px;
   svg {
    border-radius: $rM;
    &:hover{
      @include black("background-color", 80);
    }
  }
  > .reset, .ui-fold{
    font-size: 0;
  }
  .reset.active svg{
    animation: spin 3s linear infinite;
  }
}

//pc 사이드메뉴
.side-menu-wrapper {
  padding: 12px 8px;
  transition: 0.3s;
  overflow-y: auto;
  user-select: none;
  display: flex;
  flex-direction: column;
  gap: 6px;
  border-right: 1px solid;
  @include black("background-color", white);
  @include black("border-right-color", 70);
  @include custom-scrollbar;

  .side-menu-header {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 12px;

    > .reset, .ui-fold{
      cursor: pointer;
      height: $bs-s;
      display: flex;
      align-items: center;
      gap: 0;
      border: 1px solid transparent;
      border-radius: $rM;
      transition: all $tr-short;
      font-size: 0;
      &:hover{
        padding: 0 8px;
        gap: 8px;
        font-size: $fs-s;
        @include black("border-color", 70);
        @include black("background-color", 90);
        >svg{
          width: $icons-m;
          height: $icons-m;
          transition: all $tr-short;
        }
      }
    }
  }

  > .side-menu {
    width: 100%;

    .menu-items {
      margin-top: 4px;
      transition: $tr-short;
    }

    .side-menu-item {
      cursor: pointer;
      border-radius: $rL;
      @include black("color", 0);

      &:is(.menu-depth-2, .menu-depth-3) > svg {
        margin-left: auto;
      }

      > svg {
        flex-shrink: 0;
        &:first-child{
          width: 20px;
          height: 20px;
          margin-right: 4px;
        }
      }

      // 즐겨찾기 아이콘 호버시 보임처리
      // 즐겨찾기 active시 보임처리
      &:hover .side-menu-item__title + svg,
      .side-menu-item__title + svg.active{
        visibility: visible;
        opacity: 1;
      }

      &:hover{
        @include black("background-color", 90);
        > .side-menu-folding-icon:hover{
          @include black("background-color", 70);
        }
      }

      // 대메뉴 비었을때
      .menu-empty {
        width: 16px;
      }

      // 대메뉴
      &.menu-depth-1 {
        margin-top: 4px;
        padding: 4px 8px 4px 10px;
        align-items: center;
        gap: 4px;
        border-radius: $rL;
        font-size: $fs-m;
        font-weight: $fw-medium;

        &.active {
          @include colors("background-color", primaryBg);
          @include colors("color", primary);
        }
      }
      //중메뉴
      &.menu-depth-2 {
        align-items: center;
        padding: 4px 8px 4px 24px;
        transition: all $tr-short;
        gap: 4px;
        font-weight: $fw-medium;
        @include black("color", 20);

        &:hover {
          > .side-menu-folding-icon{
            @include black("background-color", 80);
            &:hover{
              @include black("background-color", 70);
            }
          }
        }

        &.active {
          @include black("color", black);
          @include black("background-color", 90);
          &:hover {
            @include black("background-color", 80);
          }
          > .side-menu-folding-icon {
            @include black("background-color", 80);
          }
        }

        // 접는 아이콘 없을때 스타일 적용
        &:not(.children) {
          padding-left: 48px;
        }

        > .side-menu-item__title {
          font-size: $fs-s;
        }

        > .side-menu-folding-icon {
          @include black("background-color", 90);
        }
      }
      //소메뉴
      &.menu-depth-3 {
        margin-left: 24px;
        padding: 2px 8px;
        align-items: center;
        border-bottom-left-radius: 0;
        border-top-left-radius: 0;
        border: 0;
        border-left-width: 1px;
        border-left-style: solid;
        transition: all $tr-short;
        @include black("border-color", 70);
        &:where(:hover, .active, :active) {
          @include colors("border-color", primary);
        }

        &.active {
          @include colors("border-color", primary);
          @include colors("color", primary);
          @include colors("background-color", primaryBg);
          // 액티브 상태일때 즐겨찾기 뜨게
          > svg {
            visibility: visible;
            opacity: 1;
          }
          &:hover > svg {
            @include colors("background-color", primary, 0, 0.1, rgba(4, 107, 251, 0.10));
          }
        }

        > .side-menu-item__title {
          font-size: $fs-s;
        }
      }
    }
    
    // title text 래핑
    .side-menu-item__title{
      flex: 1;
      white-space: nowrap;
      text-wrap: nowrap;
      text-overflow: ellipsis;
      overflow: hidden;
    }

    // 즐겨찾기 아이콘 스타일
    .side-menu-item__title + svg{
      width: 20px;
      height: 20px;
      padding: 2px;
      border-radius: $rS;
      visibility: hidden;
      opacity: 0;
      transition: all $tr-short;
      @include black("color", 40);
    }
    // 즐겨찾기 아이콘 호버 스타일
    .side-menu-item__title + svg:hover{
      @include black("background-color", 70);
    }
    .side-menu-item__title + svg:where(:hover, .active){
      @include colors("color", mark);
    }

    // 접는 아이콘 공통 스타일
    .side-menu-folding-icon {
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: $icons-s;
      height: $icons-s;
      transition: all $tr-short;
      border-radius: $rS;

      > svg {
        flex-shrink: 0;
        transition: transform $tr-short;
        transform: rotate(-90deg);
        @include black("color", 40);
      }

      &.active {
        > svg {
          transform: rotate(0deg);
        }
      }
    }
  }
}

// 왼쪽 사이드 접혔을 때 스타일
.side-mobile-menu-wrapper {
  transition: 0.3s;
  overflow-y: auto;
  user-select: none;
  border-right: 1px solid;
  @include black("background-color", white);
  @include black("border-right-color", 70);

  > .side-menu {
    width: 100%;

    &-header {
      padding: 16px 0 12px;
      margin-bottom: 12px;
      flex-direction: column-reverse;
      align-items: center;
      border-bottom: 1px solid;
      @include black("border-bottom-color", 60);
      > svg{
        border-radius: $rS;
      }
      > svg:hover {
        @include black("background-color", 80);
      }
    }

    .side-mobile-menu-item {
      cursor: pointer;
      text-align: center;

      &:hover,&.active{
        @include black("background-color", 90);
      }

      .menu-items {
        position: absolute;
        left: 54px;
        z-index: 501;
        padding: 7px 0;
        border-radius: $rM;
        box-shadow: $shadow-normal;
        @include black("background-color", white);
      }

      &.menu-depth-1 {
        padding: 12px;
        &:hover > :where(.side-menu-item__alias-title, svg),
        &.active svg {
          @include colors("color", primary);
        }
        > .side-menu-item__alias-title {
          font-size: 10px;
          overflow: hidden;
          text-overflow: ellipsis;
          white-space: nowrap;
        }
      }

      &.menu-depth-2 {
        padding: 5px 16px 2px 16px;
        border-radius: 5px;
        align-items: center;

        &:hover {
          //   box-shadow: inset 0 -1px 0 1000px rgb(0 0 0 / 10%);
        }

        &.children {
          .line {
            display: none;
          }
        }

        &:active {
          font-weight: 600;
        }

        > .side-menu-icon {
          font-size: 16px;
        }

        > .side-menu-item__title {
          padding: 2px 0;
          font-size: 12px;
        }
      }
    }
  }
  .side-menu-header {
    position: relative;
    > :is(.reset, .ui-fold){
      transition: padding $tr-short;
      &:hover{
        
        &:before{
          font-size: $fs-xs;
          box-shadow: $shadow-normal;
          border: 1px solid;
          @include black("border-color", 80);
          @include black("background-color", white);
        }
      }
    }
    > :is(.reset, .ui-fold):before{
      content: "UI 펴기";
      position: fixed;
      z-index: 999;
      display: flex;
      align-items: center;
      width: max-content;
      height: 24px;
      padding: 0 8px;
      left: 50px;
      font-size: 0;
      border-radius: $rM;
      transition: font-size $tr-short;
    }
    .reset:before{
      content: "새로고침";
    }
  }
}
