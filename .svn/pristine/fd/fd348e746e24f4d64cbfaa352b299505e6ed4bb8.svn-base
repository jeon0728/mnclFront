// 블랙 컬러값 저장
$blacks: (
  black: (
    lightness: 0,
    fallback: #000000,
  ),
  0: (
    lightness: 0.3,
    fallback: #2e2e2e,
  ),
  10: (
    lightness: 0.32,
    fallback: #333333,
  ),
  20: (
    lightness: 0.4,
    fallback: #484848,
  ),
  30: (
    lightness: 0.5,
    fallback: #636363,
  ),
  40: (
    lightness: 0.6,
    fallback: #808080,
  ),
  50: (
    lightness: 0.7,
    fallback: #9e9e9e,
  ),
  60: (
    lightness: 0.8,
    fallback: #bebebe,
  ),
  70: (
    lightness: 0.9,
    fallback: #dedede,
  ),
  80: (
    lightness: 0.95,
    fallback: #eeeeee,
  ),
  90: (
    lightness: 0.97,
    fallback: #f5f5f5,
  ),
  95: (
    lightness: 0.98,
    fallback: #f8f8f8,
  ),
  100: (
    lightness: 0.99,
    fallback: #fcfcfc,
  ),
  white: (
    lightness: 1,
    fallback: #ffffff,
  ),
);

// color func 과 balck color func 분리
// color func
// 사용법
// @include colors(color, primary);
@function is-valid-color-data($color-data) {
  @return $color-data and 
          map.get($color-data, fallback) and 
          map.get($color-data, lightness) and 
          map.get($color-data, chroma) and 
          map.get($color-data, hue);
}

// OKLCH 값 생성 헬퍼 함수
@function build-oklch($lightness, $chroma, $hue, $alpha: 1) {
  @if $alpha == 1 {
    @return string.unquote('oklch(#{$lightness} #{$chroma} #{$hue})');
  }
  @return string.unquote('oklch(#{$lightness} #{$chroma} #{$hue} / #{$alpha})');
}

@mixin colors(
  $property: 'color',
  $color-name: 'name',
  $lightness-adjust: 0,
  $alpha: 1,
  $fallback-alpha: rgb(52 73 92 / 0.2)
) {
  $color: map.get($palette, $color-name);
  
  // 색상 데이터가 유효하지 않으면 에러 처리하고 끝
  @if not is-valid-color-data($color) {
    @warn "Color '#{$color-name}' not found or invalid in palette";
    & {
      #{$property}: transparent;
    }
  }
  
  // 유효한 색상 데이터가 있을 때만 처리
  @if is-valid-color-data($color) {
    $fallback: map.get($color, fallback);
    $lightness: map.get($color, lightness) + $lightness-adjust;
    $chroma: map.get($color, chroma);
    $hue: map.get($color, hue);
    
    // 폴백 색상 적용
    & {
      #{$property}: $fallback;
    }
    
    // 알파값이 1이 아닐 때 추가 폴백
    @if $alpha != 1 {
      & {
        #{$property}: $fallback-alpha;
      }
    }
    
    // OKLCH 지원 브라우저에서 적용
    @supports (color: oklch(50% 0.1 180)) {
      & {
        #{$property}: build-oklch($lightness, $chroma, $hue, $alpha);
      }
    }
  }
}
// color func

// black func
// 예시
// @include black(color, 0);
@mixin black($property, $level: 0, $alpha: 1, $fallback-alpha: rgb(0 0 0 / 0.1)) {
  $color: map.get($blacks, $level);
  $lightness: map.get($color, lightness);
  $fallback: map.get($color, fallback);
  
  & {
    #{$property}: $fallback;
  }
  
  @if $alpha != 1 {
    & {
      #{$property}: $fallback-alpha;
    }
  }

  // 지원하는 브라우저에서만 적용
  // 문자열 치환 필요
  @supports (color: oklch(50% 0.1 180)) {
    #{$property}: string.unquote('oklch(#{$lightness} 0 0)');
    @if $alpha != 1 {
      & {
        #{$property}: string.unquote('oklch(#{$lightness} 0 0 / #{$alpha})');
      }
    }
  }
}
// black func

//shadow func
@mixin shadows($property: '0 0 0', $color-name: 'name', $alpha: 1) {
  $color: map.get($palette, $color-name);
  $lightness: map.get($color, lightness);
  $chroma: map.get($color, chroma);
  $hue: map.get($color, hue);
  $fallback: map.get($color, fallback);

  box-shadow: string.unquote(
    'oklch(#{$lightness} #{$chroma} #{$hue} / #{$alpha})'
  );
  box-shadow: string.unquote('#{$property} #{$fallback}20');
}
