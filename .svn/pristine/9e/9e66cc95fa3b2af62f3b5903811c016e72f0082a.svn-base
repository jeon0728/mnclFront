<template>
  <Popover :active="isOpen">
    <template #component>
      <div class="profile-container">
        <div class="profile-image" @click="togglePopover" tabindex="-1" @focusout="isOpen = false">
          <template v-if="!hasError && props.profileImage">
            <img
              :src="props.profileImage"
              alt="profile"
              width="40"
              height="40"
              @error="hasError = true"
            />
          </template>
          <template v-else>
            <div class="profile-actions-avatar">
              <div v-if="profileName?.charAt(0)">
                {{ profileName?.charAt(0) }}
              </div>
              <PhUser v-else :size="20"/>
            </div>
          </template>
        </div>
      </div>
    </template>

    <template #popover>
      <ul
        class="profile-actions"
        @mousedown.prevent.stop
      >
        <li class="profile-actions-container">
          <template v-if="props.profileImage">
            <img
              :src="props.profileImage"
              alt="profile"
              width="40"
              height="40"
              @error="hasError = true"
            />
          </template>
          <template v-else>
            <div class="profile-actions-image">
              <div v-if="profileName?.charAt(0)">
                {{ profileName?.charAt(0) }}
              </div>
              <PhUser v-else :size="20"/>
            </div>
          </template>

          <div>
            <div class="profile-actions-user-name">{{ profileName }}</div>
            <div class="profile-actions-user-dept">한국비즈넷</div>
          </div>
        </li>

        <li class="info" @click="() => {}">개인 설정</li>
        <li class="login-out" @click="handleLogout">로그아웃</li>
      </ul>
    </template>
  </Popover>
</template>
