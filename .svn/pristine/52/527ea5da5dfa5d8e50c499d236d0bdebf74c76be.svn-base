                    <div class="dashboard-detail-num">2,340</div>
                  </div>
                  <i class="dashboard-detail-icon">
                    <PhQuestionMark :size="24" :fill="'#fff'"/>
                  </i>
                </li>
                <li class="flex flex-1 justify-between amended">
