<template>
  <PageLayout title="DASH BOARD">

    <template #content>
      <Card>
        <template #content>
          <div class="contents-inner">
            <ul>
              <li>
                <Label>Carrier</Label>
                <CodeBox placeholder="선사검색"/>
              </li>
              <li>
                <Label>SC contract</Label>
                <CodeBox placeholder="SC contract 검색"/>
              </li>
              <li>
                <Label>조회조건 From</Label>
                <DateBox/>
              </li>
              <li>
                <Label>조회조건 To</Label>
                <DateBox/>
              </li>
            </ul>
          </div>
        </template>
      </Card>

      <!-- detail 영역 -->
      <div class="dashboard-detail">
        <div class="flex-1">
          <Card description="Allocation Details (TEU)">
            <template #content>
              <ul class="grid grid-2">
                <li class="flex flex-1 justify-between allocated">
                  <div class="flex-column">
                    <div class="dashboard-detail-name">Allocated</div>
                    <div class="dashboard-detail-num">2,340</div>
                  </div>
                  <i class="dashboard-detail-icon">
                    <PhStackSimple :size="24" :fill="'#fff'"/>
                  </i>
                </li>
                <li class="flex flex-1 justify-between booked">
                  <div class="flex-column">
                    <div class="dashboard-detail-name">Booked</div>
                    <div class="dashboard-detail-num">2,340</div>
                  </div>
                  <i class="dashboard-detail-icon">
                    <PhCalendarCheck :size="24" :fill="'#fff'"/>
                  </i>
                </li>
                <li class="flex flex-1 justify-between available">
                  <div class="flex-column">
                    <div class="dashboard-detail-name">Available</div>
                    <div class="dashboard-detail-num">2,340</div>
                  </div>
                  <i class="dashboard-detail-icon">
                    <PhSquaresFour :size="24" :fill="'#fff'"/>
                  </i>
                </li>
                <li class="flex flex-1 justify-between pending">
                  <div class="flex-column">
