@use '../../variable' as *;

.loading-dots-3 {
  $scale: 0.4 !default;
  $delay: 500ms !default;
  $time: 1.7s !default;
  $icons-xl : 50px;
  height: $icons-xl;
  width: $icons-xl;
  animation-delay: $delay;
  &::after {
    content: '';
    display: block;
    position: absolute;
    inset: 0;
    margin: auto;
    width: $icons-xl;
    height: $icons-xl;
    border-radius: 50%;
    opacity: 0;
    animation: loader-dots-3 $time cubic-bezier(0.77, 0, 0.175, 1) $delay infinite;
    @include colors('background-color', loader);
  }

  @keyframes loader-dots-3 {
    0% {
      transform: scale(0);
      opacity: 0;
    }
    50% {
      transform: scale(1);
      opacity: 1;
    }
    100% {
      transform: scale(0);
      opacity: 0;
    }
  }

  &-inner {
    display: block;
    position: absolute;
    inset: 0;
    margin: auto;
    width: $icons-xl;
    height: $icons-xl;
    opacity: 0;
    animation: loader-dots-3-inner $time cubic-bezier(0.77, 0, 0.175, 1) $delay infinite;

  }

  @keyframes loader-dots-3-inner {
    0% {
      opacity: 1;
      transform: rotate(0deg);
    }
    50% {
      opacity: 1;
      transform: rotate(180deg);
    }
    100% {
      opacity: 1;
      transform: rotate(360deg);
    }
  }

  &-inner::before,
  &-inner::after {
    content: '';
    display: block;
    position: absolute;
    inset: 0;
    margin: auto;
    width: $icons-xl;
    height: $icons-xl;
    border-radius: 50%;
    animation: loader-dots-3-before $time cubic-bezier(0.77, 0, 0.175, 1) $delay infinite;

    @include colors('background-color', loaderSecond);
  }

  @keyframes loader-dots-3-before {
    0% {
      transform: translate3d(0, 0, 0) scale(1.5);
    }
    50% {
      transform: translate3d(-$icons-xl*1.5, 0, 0) scale($scale);
    }
    100% {
      transform: translate3d(0, 0, 0) scale(1.5);
    }
  }
  &-inner::after {
    animation: loader-dots-3-after $time cubic-bezier(0.77, 0, 0.175, 1) $delay infinite;
  }

  @keyframes loader-dots-3-after {
    0% {
      transform: translate3d(0, 0, 0) scale(1.5);
    }
    50% {
      transform: translate3d($icons-xl*1.5, 0, 0) scale($scale);
    }
    100% {
      transform: translate3d(0, 0, 0) scale(1.5);
    }
  }
}

// 안씀
.loading-filter {
  display: none;
  position: absolute;
  width: 0;
  height: 0;
}

.loading-dots-2 {
  $time: 2s !default;

  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  &:before,
  &:after {
    content: '';
    left: 0;
    position: absolute;
    width: $icons-xl;
    height: $icons-xl;
    border-radius: 50%;
    animation: loading-dots-2 $time infinite ease-in-out;
    @include colors('background-color', loader);
  }

  &:after {
    animation-delay: -1s;
    @include colors('background-color', loaderSecond);
  }
}

@keyframes loading-dots-2 {
  0% {
    z-index: 1;
    transform: translate(0, 0);
  }
  50% {
    z-index: 1;
    transform: translate(120%, 0);
  }
  50.1% {
    z-index: 0;
    transform: translate(120%, 0);
  }
  100% {
    z-index: 0;
    transform: translate(0, 0);
  }
}
