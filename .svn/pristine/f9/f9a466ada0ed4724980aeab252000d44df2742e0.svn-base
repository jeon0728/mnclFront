@use '../../variable' as *;

// input + text 조합
// 최소 200, 200넘으면 최대로 늘어남
.search-form {
  display: grid;
  align-items: center;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  column-gap: 32px;
  row-gap: 16px;
  width: 100%;

  .search-form-field {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 0; // flexbox에서 텍스트 오버플로우 방지

    .search-form-label {
      @include label;
    }

    // input double flex
    .input-flex-1,
    .date-range-inputs {
      display: flex;
      gap: 8px;
      align-items: center;
    }

    .input-flex-1 > *,
    .date-range-inputs > * {
      display: flex;
      gap: 8px;
      align-items: center;
      flex: 1 0 130px;
    }
  }
}

.input-label-column {
  display: flex;
  flex-direction: column;
  gap: 8px;
  label.label {
    @include label;
  }
}

.input-label-flex {
  display: flex;
  align-items: center;
  gap: 8px;
  label.label {
    flex: 0 0 auto;
    @include label;
  }
}

.input-label-s {
  display: flex;
  align-items: center;
  gap: 8px;
  label.label {
    @include labelXS;
  }
}