// 이벤트 툴팁 전역 스타일
.fc-tooltip {
	position: fixed;
	z-index: 99999;
	min-width: 150px;
	background: #fcfcfc;
	border: 1px solid #ccc;
	border-radius: 8px;
	box-shadow: 1px 2px 8px 0 rgba(0, 0, 0, 0.10);
	padding: 8px 12px;
	font-size: 14px;
	color: #333;
	pointer-events: none;
	white-space: nowrap;

	/* 삼각형 테두리 */
	&::before {
		content: '';
		position: absolute;
		top: -8px;
		left: 12px;
		border-width: 0 7px 8px 7px;
		border-style: solid;
		border-color: transparent transparent #ccc transparent;
	}

	/* 삼각형 배경 */
	&::after {
		content: '';
		position: absolute;
		top: -6px;
		left: 13px;
		border-width: 0 6px 7px 6px;
		border-style: solid;
		border-color: transparent transparent #fcfcfc transparent;
	}
}

.fc-tooltip-clickable {
cursor: pointer;
	pointer-events: auto;
	transition: background-color 0.2s;
	border-radius: 4px;
	padding: 6px 4px;
	margin: -2px -4px;

    &:hover {
			background-color: #f5f5f5;
    }
}